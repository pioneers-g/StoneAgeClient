 * Returns 1 if position is walkable, 0 if blocked
 * Mode parameter determines check type (8-way, with range, etc.)
 */
int map_check_collision(int x, int y, int mode) {
    /* Check bounds */
    if (x < 0 || y < 0 || x >= (int)g_map.width || y >= (int)g_map.height) {
        return 0;  /* Out of bounds */
    }

    /* Check tile at position */
    /* TODO: Implement actual tile collision check based on map data */
    /* For now, assume all in-bounds positions are walkable */
    (void)mode;  /* Mode determines collision check type */

    return 1;  /* Walkable */
}

/*
 * Set current map ID - FUN_00440dd0
 * Stores map ID and calls coordinate initialization
 */
void map_set_map_id(u32 map_id) {
    g_map.current_map_id = map_id;
    /* Coordinate initialization is done separately via map_set_coordinates */
}

/*
 * Set player coordinates on map - FUN_00440df0
 * Initializes camera and view bounds based on coordinates
 *
 * Binary analysis:
 * - Sets DAT_0458118c, DAT_04581d3c to x
 * - Sets DAT_04581184, DAT_04581d40 to y
 * - Calculates camera position using _DAT_0049c31c (1/64 scale factor)
 * - Resets view bounds to 0xFFFFFFFF (invalid)
 * - Calls FUN_00419a40() and FUN_0041cdd0() for additional setup
 */
void map_set_coordinates(int x, int y) {
    /* Store world coordinates */
    g_map.player_x = x;
    g_map.player_y = y;

    /* Set camera position (scaled by 1/64 for isometric) */
    s_iso_camera_x = (float)x * 0.015625f;  /* 1/64 */
    s_iso_camera_y = (float)y * 0.015625f;

    /* Initialize view bounds as invalid */
    g_map.offset_x = 0;
    g_map.offset_y = 0;

    /* Reset camera state */
    g_map.camera_x = x * 32;  /* Convert to screen coordinates */
    g_map.camera_y = y * 24;
    g_map.target_camera_x = g_map.camera_x;
    g_map.target_camera_y = g_map.camera_y;

    /* Mark as needing update */
    g_map.loaded = 1;
}

/*
 * Load map data file - FUN_00440530
 * Opens map/%d.dat file and reads dimensions
 *
 * Binary analysis:
 * - Opens file using format "map/%d.dat"
 * - If file exists, reads 3 layers of tile data
 * - Each layer has width * height * 2 bytes (u16 per tile)
 * - Updates map dimensions
 */
void map_load_map_data(u32 map_id, int width, int height) {
    char path[260];
    HANDLE hFile;
    DWORD bytes_read;
    int layer, row, col;
    u16 tile_value;

    /* Format path: map/%d.dat */
    snprintf(path, sizeof(path), "data/map/%d.dat", map_id);

    hFile = CreateFileA(path, GENERIC_READ, FILE_SHARE_READ, NULL,
        OPEN_EXISTING, FILE_ATTRIBUTE_NORMAL, NULL);

    if (hFile == INVALID_HANDLE_VALUE) {
        /* File doesn't exist - dimensions stay as-is */
        return;
    }

    /* Read header: 2 ints for width/height */
    int file_width, file_height;
    ReadFile(hFile, &file_width, 4, &bytes_read, NULL);
    ReadFile(hFile, &file_height, 4, &bytes_read, NULL);

    /* Check if dimensions match expected */
    if (file_width != width || file_height != height) {
        /* Dimensions don't match - close and reopen for writing */
        CloseHandle(hFile);
        return;
    }

    /* Initialize field buffers */
    map_init_field_buffers(width, height);

    /* Read 3 layers of tile data */
    for (layer = 0; layer < 3; layer++) {
        for (row = 0; row < height; row++) {
            for (col = 0; col < width; col++) {
                if (!ReadFile(hFile, &tile_value, 2, &bytes_read, NULL)) {
                    break;
                }
                map_set_field_tile(col, row, tile_value, 0);
            }
        }
    }

    CloseHandle(hFile);
}

