/*
 * Stone Age Client - Login System Implementation
 * Reverse engineered from sa_9061.exe (FUN_00420590, FUN_0045f4d0, FUN_0043bb10)
 *
 * Login protocol commands:
 * - ClientLogin: Authentication request (FUN_0043bb10)
 * - CharList: Request character list
 * - CharLogin: Select character to play
 * - CharLogout: Logout from game
 * - CreateNewChar: Create new character
 * - CharDelete: Delete character
 *
 * Connection states from FUN_0045f4d0:
 * - State 0: Create socket, connect
 * - State 1-70 (0x46): Wait for connection
 * - State 71 (0x47): Send ClientLogin with encrypted credentials
 * - State 81-98 (0x51-0x62): Wait for login response
 * - State 99: Connected
 *
 * Login screen states from FUN_00420590:
 * - State 0: Cleanup, init UI
 * - State 1: Render login screen
 * - State 2: Handle input
 * - State 3: Creating connection widget
 * - State 4: Wait for server response
 * - State 100: Error display
 * - State 101: Retry after error
 *
 * Encryption: See login_crypto.c for DES-like block cipher implementation
 */

#include <windows.h>
#include <winsock2.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include "types.h"
#include "login.h"
#include "login_crypto.h"
#include "network.h"
#include "logger.h"
#include "directx.h"
#include "render.h"
#include "input.h"
#include "commandline.h"

/* Global login context */
LoginContext g_login = {0};

/*
 * Initialize login system
 */
int login_init(void) {
    memset(&g_login, 0, sizeof(LoginContext));

    g_login.state = LOGIN_STATE_DISCONNECTED;
    g_login.conn_state = CONN_STATE_NONE;
    g_login.screen_state = LOGIN_SCREEN_INIT;
    g_login.server_port = 4567; /* Default port */
    g_login.selected_char_index = -1;
    g_login.protocol_mode = PROTOCOL_MODE_TEXT;
    g_login.input_focus = 0;  /* Username focus by default */

    /* Initialize text input boxes - FUN_00420fb0 pattern */
    login_init_text_input(&g_login.username_box, 300, 170, 31, 0, 0xFFFFFFFF);  /* Username */
    login_init_text_input(&g_login.password_box, 300, 200, 31, 1, 0xFFFFFFFF);  /* Password (masked) */

    /* Auto-fill credentials from command line - FUN_0043f4b0 pattern
     * If userid parameter was provided, pre-populate login fields
     */
    if (g_cmdline.user_id[0]) {
        strncpy(g_login.username, g_cmdline.user_id, MAX_USERNAME - 1);
        strncpy(g_login.username_box.buffer, g_cmdline.user_id, 255);
        g_login.username_cursor = (u32)strlen(g_cmdline.user_id);
        g_login.username_box.cursor_index = (u8)g_login.username_cursor;
        LOG_DEBUG("Pre-filled username from command line");
    }

    if (g_cmdline.password[0]) {
        strncpy(g_login.password, g_cmdline.password, MAX_PASSWORD - 1);
        strncpy(g_login.password_box.buffer, g_cmdline.password, 255);
        g_login.password_cursor = (u32)strlen(g_cmdline.password);
        g_login.password_box.cursor_index = (u8)g_login.password_cursor;
        LOG_DEBUG("Pre-filled password from command line");
    }

    LOG_INFO("Login system initialized");
    return 1;
}

/*
 * Shutdown login system
 */
void login_shutdown(void) {
    login_disconnect();
    memset(&g_login, 0, sizeof(LoginContext));
    LOG_INFO("Login system shutdown");
}

/*
 * Connect to login server - FUN_0045f4d0 pattern
 */
int login_connect(const char* host, u16 port) {
    strncpy(g_login.server_host, host, MAX_SERVER - 1);
    g_login.server_port = port;
    g_login.start_time = timeGetTime();
    g_login.state = LOGIN_STATE_CONNECTING;
    g_login.conn_state = CONN_STATE_CONNECTING;

    /* Connect via network module */
    if (network_connect(host, port)) {
        LOG_INFO("Connecting to %s:%u", host, port);
        return 1;
    }

    g_login.state = LOGIN_STATE_DISCONNECTED;
    g_login.conn_state = CONN_STATE_NONE;
    return 0;
}

/*
 * Disconnect from server
 */
void login_disconnect(void) {
    if (g_login.state != LOGIN_STATE_DISCONNECTED) {
        network_disconnect();
        g_login.state = LOGIN_STATE_DISCONNECTED;
        g_login.conn_state = CONN_STATE_NONE;
        g_login.logged_in = 0;
        g_login.in_game = 0;
        g_login.login_sent = 0;

        LOG_INFO("Disconnected from server");
    }
}

/*
 * Check if connected
 */
int login_is_connected(void) {
    return g_login.state != LOGIN_STATE_DISCONNECTED;
}

/*
 * Send ClientLogin command - FUN_0043bb10 pattern
 * Format: ClientLogin|encrypted_username|encrypted_password
 */
int login_auth(const char* username, const char* password) {
    char packet[256];
    char enc_user[32];
    char enc_pass[32];

    if (!username || !password) {
        return 0;
    }

    if (g_login.state != LOGIN_STATE_CONNECTING &&
        g_login.state != LOGIN_STATE_HANDSHAKE) {
        LOG_WARN("Not ready for authentication");
        return 0;
    }

    strncpy(g_login.username, username, MAX_USERNAME - 1);
    strncpy(g_login.password, password, MAX_PASSWORD - 1);

    /* Encrypt credentials */
    login_encrypt_user_pass(username, password, enc_user, enc_pass);

    g_login.state = LOGIN_STATE_AUTH;
    g_login.last_activity = timeGetTime();

    /* Build and send ClientLogin packet */
    _snprintf(packet, sizeof(packet), "ClientLogin|%s|%s\n", enc_user, enc_pass);
    network_send(packet, strlen(packet));

    g_login.login_sent = 1;

    LOG_DEBUG("Sent ClientLogin for user: %s", username);
    return 1;
}

/*
 * Handle login result - FUN_0045f4d0 pattern
 * Response byte: 'A' = accepted, 'E' = error, 'L' = login success
 */
void login_handle_result(void* data, u32 size) {
    u8* ptr = (u8*)data;
    char response;

    if (size < 1) return;

    response = *ptr++;
    g_login.first_byte = response;

    switch (response) {
        case SERVER_RESPONSE_ACCEPT:
            /* Authentication accepted, waiting for 'L' */
            g_login.result = LOGIN_SUCCESS;
            g_login.state = LOGIN_STATE_HANDSHAKE;
            g_login.protocol_mode = PROTOCOL_MODE_BINARY;

            LOG_DEBUG("Server accepted connection");
            break;

        case SERVER_RESPONSE_LOGIN_OK:
            /* Full login success */
            g_login.result = LOGIN_SUCCESS;
            g_login.logged_in = 1;
            g_login.state = LOGIN_STATE_SERVER_LIST;

            /* Parse session key if present */
            if (size > 1) {
                strncpy(g_login.session_key, (char*)ptr,
                        sizeof(g_login.session_key) - 1);
            }

            LOG_INFO("Login successful for user: %s", g_login.username);

            /* Request server list */
            login_request_servers();
            break;

        case SERVER_RESPONSE_ERROR:
            /* Error response */
            if (size > 1) {
                u8 error_code = *ptr;
                switch (error_code) {
                    case 0x01:
                        g_login.result = LOGIN_ERR_INVALID_USER;
                        strcpy(g_login.error_message, "Invalid username");
                        break;
                    case 0x02:
                        g_login.result = LOGIN_ERR_INVALID_PASS;
                        strcpy(g_login.error_message, "Invalid password");
                        break;
                    case 0x03:
                        g_login.result = LOGIN_ERR_ALREADY_LOGGED;
                        strcpy(g_login.error_message, "Already logged in");
                        break;
                    case 0x04:
                        g_login.result = LOGIN_ERR_SERVER_DOWN;
                        strcpy(g_login.error_message, "Server maintenance");
                        break;
                    case 0x05:
                        g_login.result = LOGIN_ERR_VERSION_MISMATCH;
                        strcpy(g_login.error_message, "Version mismatch");
                        break;
                    case 0x06:
                        g_login.result = LOGIN_ERR_BANNED;
                        strcpy(g_login.error_message, "Account banned");
                        break;
                    default:
                        g_login.result = LOGIN_ERR_CONNECTION_FAILED;
                        strcpy(g_login.error_message, "Unknown error");
                        break;
                }
            }
            g_login.state = LOGIN_STATE_ERROR;
            LOG_WARN("Login failed: %s", g_login.error_message);
            break;

        default:
            LOG_WARN("Unknown login response: 0x%02X", response);
            break;
    }
}

/*
 * Auto login with saved credentials
 */
int login_auto_auth(void) {
    if (g_login.remember_pass && g_login.username[0] && g_login.password[0]) {
        return login_auth(g_login.username, g_login.password);
    }
    return 0;
}

/*
 * Request server list
 */
void login_request_servers(void) {
    char packet[] = "ProcGet\n";
    network_send(packet, strlen(packet));
    g_login.state = LOGIN_STATE_SERVER_LIST;
    LOG_DEBUG("Requesting server list");
}

/*
 * Handle server list response
 */
void login_handle_servers(void* data, u32 size) {
    u8* ptr = (u8*)data;
    int i;
    ServerInfo* server;

    g_login.server_count = 0;

    for (i = 0; i < MAX_SERVERS && ptr < (u8*)data + size; i++) {
        server = &g_login.servers[i];

        server->id = *(u32*)ptr; ptr += 4;
        if (server->id == 0) continue;

        strncpy(server->name, (char*)ptr, sizeof(server->name) - 1);
        ptr += strlen(server->name) + 1;

        strncpy(server->host, (char*)ptr, sizeof(server->host) - 1);
        ptr += strlen(server->host) + 1;

        server->port = *(u16*)ptr; ptr += 2;
        server->population = *(u16*)ptr; ptr += 2;
        server->status = *(u8*)ptr; ptr += 1;

        g_login.server_count++;
    }

    LOG_INFO("Received %d servers", g_login.server_count);
}

/*
 * Select server
 */
int login_select_server(int index) {
    ServerInfo* server;

    if (index < 0 || index >= g_login.server_count) {
        return 0;
    }

    server = &g_login.servers[index];
    if (server->status != 0) {
        LOG_WARN("Server %s is not available", server->name);
        return 0;
    }

    g_login.selected_server_index = index;
    g_login.state = LOGIN_STATE_CHAR_LIST;

    /* Request character list */
    login_request_characters();

    LOG_INFO("Selected server: %s", server->name);
    return 1;
}

/*
 * Request character list - CharList command
 */
void login_request_characters(void) {
    char packet[] = "CharList||\n";
    network_send(packet, strlen(packet));
    LOG_DEBUG("Requesting character list");
}

/*
 * Handle character list response
 */
void login_handle_characters(void* data, u32 size) {
    u8* ptr = (u8*)data;
    int i;
    CharacterInfo* character;

    g_login.char_count = 0;

    for (i = 0; i < MAX_CHARACTERS && ptr < (u8*)data + size; i++) {
        character = &g_login.characters[i];

        character->id = *(u32*)ptr; ptr += 4;
        if (character->id == 0) {
            character->exists = 0;
            continue;
        }

        character->exists = 1;
        strncpy(character->name, (char*)ptr, sizeof(character->name) - 1);
        ptr += strlen(character->name) + 1;

        character->level = *(u16*)ptr; ptr += 2;
        character->job = *(u16*)ptr; ptr += 2;
        character->face = *(u8*)ptr; ptr += 1;
        character->body = *(u8*)ptr; ptr += 1;
        character->map_id = *(u32*)ptr; ptr += 4;
        character->x = *(u16*)ptr; ptr += 2;
        character->y = *(u16*)ptr; ptr += 1;

        g_login.char_count++;
    }

    g_login.state = LOGIN_STATE_CHAR_LIST;
    LOG_INFO("Received %d characters", g_login.char_count);
}

/*
 * Select character
 */
int login_select_character(int index) {
    CharacterInfo* character;

    if (index < 0 || index >= MAX_CHARACTERS) {
        return 0;
    }

    character = &g_login.characters[index];
    if (!character->exists) {
        return 0;
    }

    g_login.selected_char_index = index;
    g_login.state = LOGIN_STATE_CHAR_SELECT;

    LOG_INFO("Selected character: %s", character->name);
    return 1;
}

/*
 * Create new character - CreateNewChar command
 */
int login_create_character(const char* name, u8 face, u8 body, u16 job) {
    char packet[128];

    if (!name || strlen(name) == 0) {
        return 0;
    }

    if (g_login.char_count >= MAX_CHARACTERS) {
        LOG_WARN("No free character slots");
        return 0;
    }

    /* Format: CreateNewChar|name|face|body|job */
    _snprintf(packet, sizeof(packet), "CreateNewChar|%s|%d|%d|%d\n",
              name, face, body, job);
    network_send(packet, strlen(packet));

    LOG_DEBUG("Creating character: %s", name);
    return 1;
}

/*
 * Handle character create result
 */
void login_handle_create_result(void* data, u32 size) {
    u8* ptr = (u8*)data;
    u8 result;

    result = *ptr++;

    if (result == 0) {
        /* Success - refresh character list */
        login_request_characters();
        LOG_INFO("Character created successfully");
    } else {
        LOG_WARN("Failed to create character: result %d", result);
    }
}

/*
 * Delete character - CharDelete command
 */
int login_delete_character(int index) {
    char packet[64];
    CharacterInfo* character;

    if (index < 0 || index >= MAX_CHARACTERS) {
        return 0;
    }

    character = &g_login.characters[index];
    if (!character->exists) {
        return 0;
    }

    /* Send delete request with character name */
    _snprintf(packet, sizeof(packet), "CharDelete|%s\n", character->name);
    network_send(packet, strlen(packet));

    LOG_DEBUG("Deleting character: %s", character->name);
    return 1;
}

/*
 * Handle character delete result
 */
void login_handle_delete_result(void* data, u32 size) {
    u8* ptr = (u8*)data;
    u8 result;
    u32 char_id;
    int i;

    result = *ptr++;
    char_id = *(u32*)ptr;

    if (result == 0) {
        /* Find and remove character */
        for (i = 0; i < MAX_CHARACTERS; i++) {
            if (g_login.characters[i].id == char_id) {
                LOG_INFO("Deleted character: %s", g_login.characters[i].name);
                memset(&g_login.characters[i], 0, sizeof(CharacterInfo));
                g_login.char_count--;
                break;
            }
        }
    } else {
        LOG_WARN("Failed to delete character: result %d", result);
    }
}

/*
 * Enter game with selected character - CharLogin command
 */
int login_enter_game(void) {
    char packet[64];
    CharacterInfo* character;

    if (g_login.selected_char_index < 0 ||
        g_login.selected_char_index >= MAX_CHARACTERS) {
        return 0;
    }

    character = &g_login.characters[g_login.selected_char_index];
    if (!character->exists) {
        return 0;
    }

    /* Send CharLogin with character name */
    _snprintf(packet, sizeof(packet), "CharLogin|%s\n", character->name);
    network_send(packet, strlen(packet));

    g_login.state = LOGIN_STATE_ENTERING_GAME;
    LOG_INFO("Entering game with character: %s", character->name);
    return 1;
}

/*
 * Handle enter game response
 */
void login_handle_enter_game(void* data, u32 size) {
    u8* ptr = (u8*)data;
    u8 result;

    result = *ptr++;

    if (result == 0) {
        g_login.state = LOGIN_STATE_IN_GAME;
        g_login.in_game = 1;
        LOG_INFO("Entered game successfully");
    } else {
        LOG_WARN("Failed to enter game: result %d", result);
        g_login.state = LOGIN_STATE_CHAR_LIST;
    }
}

/*
 * Logout completely - CharLogout command
 */
int login_logout(void) {
    char packet[] = "CharLogout||\n";
    network_send(packet, strlen(packet));

    g_login.in_game = 0;
    g_login.logged_in = 0;
    g_login.state = LOGIN_STATE_DISCONNECTED;

    LOG_INFO("Logged out");
    return 1;
}

/*
 * Return to character selection
 */
int login_return_to_char_select(void) {
    if (g_login.in_game) {
        char packet[] = "CharLogout||\n";
        network_send(packet, strlen(packet));

        g_login.in_game = 0;
        g_login.state = LOGIN_STATE_CHAR_LIST;

        LOG_INFO("Returned to character selection");
        return 1;
    }
    return 0;
}

/*
 * Get login state
 */
LoginState login_get_state(void) {
    return g_login.state;
}

/*
 * Get error message
 */
const char* login_get_error_message(void) {
    return g_login.error_message;
}

/*
 * Check if in game
 */
int login_is_in_game(void) {
    return g_login.in_game;
}

/*
 * Process connection state machine - FUN_0045f4d0 pattern
 */
int login_process_connect(void) {
    u32 current_time = timeGetTime();

    switch (g_login.conn_state) {
        case CONN_STATE_NONE:
            /* Not connecting */
            break;

        case CONN_STATE_CONNECTING:
            /* Wait for connection (states 1-70 in original) */
            if (network_is_connected()) {
                g_login.conn_state = CONN_STATE_SEND_LOGIN;
                g_login.state = LOGIN_STATE_HANDSHAKE;
            }
            break;

        case CONN_STATE_SEND_LOGIN:
            /* Send login (state 0x47 in original) */
            if (g_login.login_sent) {
                g_login.conn_state = CONN_STATE_WAIT_RESPONSE;
            }
            break;

        case CONN_STATE_WAIT_RESPONSE:
            /* Wait for response (states 0x51-0x62 in original) */
            if (g_login.logged_in) {
                g_login.conn_state = CONN_STATE_CONNECTED;
            }
            break;

        case CONN_STATE_CONNECTED:
            /* Fully connected */
            break;
    }

    /* Check for timeout - 600000ms (10 minutes) from FUN_0045f4d0 */
    if (g_login.conn_state > CONN_STATE_NONE &&
        g_login.conn_state < CONN_STATE_CONNECTED) {
        if (current_time - g_login.start_time > LOGIN_TIMEOUT) {
            strcpy(g_login.error_message, "Connection timeout");
            g_login.result = LOGIN_ERR_TIMEOUT;
            g_login.state = LOGIN_STATE_ERROR;
            login_disconnect();
            LOG_WARN("Login timeout");
            return -1;
        }
    }

    return 0;
}

/*
 * Update login state machine
 */
void login_update(void) {
    login_process_connect();

    /* Additional state updates can be added here */
}

/*
 * Handle login packet
 */
void login_handle_packet(void* data, u32 size) {
    u8* ptr = (u8*)data;
    u16 opcode;

    if (size < 2) return;

    opcode = *(u16*)ptr; ptr += 2;

    switch (opcode) {
        case 0x0002:  /* Login result */
            login_handle_result(ptr, size - 2);
            break;
        case 0x0004:  /* Character list */
            login_handle_characters(ptr, size - 2);
            break;
        case 0x0016:  /* Enter map */
            login_handle_enter_game(ptr, size - 2);
            break;
        default:
            LOG_DEBUG("Unknown login opcode: 0x%04X", opcode);
            break;
    }
}

/*
 * Get character by index
 */
CharacterInfo* login_get_character(int index) {
    if (index < 0 || index >= MAX_CHARACTERS) {
        return NULL;
    }
    return &g_login.characters[index];
}

/*
 * Get selected character
 */
CharacterInfo* login_get_selected_character(void) {
    if (g_login.selected_char_index < 0 ||
        g_login.selected_char_index >= MAX_CHARACTERS) {
        return NULL;
    }
    return &g_login.characters[g_login.selected_char_index];
}

/*
 * Get character count
 */
int login_get_character_count(void) {
    return g_login.char_count;
}

/*
 * Get server by index
 */
ServerInfo* login_get_server(int index) {
    if (index < 0 || index >= g_login.server_count) {
        return NULL;
    }
    return &g_login.servers[index];
}

/*
 * Get server count
 */
int login_get_server_count(void) {
    return g_login.server_count;
}

/*
 * Handle text protocol login result - FUN_0045fa40 pattern
 */
void login_handle_text_result(const char* result) {
    if (result && result[0] == '0') {
        g_login.state = LOGIN_STATE_SERVER_LIST;
        g_login.logged_in = 1;
        g_login.conn_state = CONN_STATE_CONNECTED;
        LOG_INFO("Login successful");
    } else {
        g_login.result = LOGIN_ERR_INVALID_USER;
        strncpy(g_login.error_message, "Login failed",
                sizeof(g_login.error_message) - 1);
        g_login.state = LOGIN_STATE_ERROR;
        LOG_WARN("Login failed: %s", result);
    }
}

/*
 * Handle text protocol character create result
 */
void login_handle_create_text_result(const char* result, const char* name) {
    if (result && result[0] == '0') {
        LOG_INFO("Character created: %s", name ? name : "");
        /* Refresh character list */
        login_request_characters();
    } else {
        LOG_WARN("Character create failed: %s", result);
    }
}

/*
 * Handle text protocol character delete result
 */
void login_handle_delete_text_result(const char* result, const char* name) {
    if (result && result[0] == '0') {
        LOG_INFO("Character deleted: %s", name ? name : "");
        /* Refresh character list */
        login_request_characters();
    } else {
        LOG_WARN("Character delete failed: %s", result);
    }
}

/*
 * Handle text protocol character login result
 */
void login_handle_char_login_result(const char* result, const char* name) {
    if (result && result[0] == '0') {
        g_login.state = LOGIN_STATE_ENTERING_GAME;
        LOG_INFO("Entering game with character: %s", name ? name : "");
    } else {
        LOG_WARN("Character login failed: %s", result);
    }
}

/*
 * Handle text protocol character list
 */
void login_handle_char_list_text(const char* param1, const char* param2) {
    /* Parse character data from text */
    LOG_DEBUG("Character list: %s, %s", param1 ? param1 : "", param2 ? param2 : "");
}

/*
 * Login screen initialization - FUN_00420590 state 0
 */
void login_screen_init(void) {
    /* State 0: Cleanup and initialize UI */
    if (g_login.screen_state == LOGIN_SCREEN_INIT) {
        /* Close any existing connection */
        login_disconnect();

        /* Clear credentials */
        memset(g_login.username, 0, sizeof(g_login.username));
        memset(g_login.password, 0, sizeof(g_login.password));
        memset(g_login.encrypted_user, 0, sizeof(g_login.encrypted_user));
        memset(g_login.encrypted_pass, 0, sizeof(g_login.encrypted_pass));

        /* Reset state */
        g_login.state = LOGIN_STATE_DISCONNECTED;
        g_login.conn_state = CONN_STATE_NONE;
        g_login.login_sent = 0;
        g_login.logged_in = 0;
        g_login.input_focus = 0;
        g_login.first_render = 0;

        /* Clear text input boxes */
        memset(&g_login.username_box, 0, sizeof(TextInputBox));
        memset(&g_login.password_box, 0, sizeof(TextInputBox));

        /* Re-initialize text input boxes */
        login_init_text_input(&g_login.username_box, 300, 170, 31, 0, 0xFFFFFFFF);
        login_init_text_input(&g_login.password_box, 300, 200, 31, 1, 0xFFFFFFFF);

        /* Transition to render state */
        g_login.screen_state = LOGIN_SCREEN_RENDER;

        LOG_DEBUG("Login screen initialized");
    }
}

/*
 * Login screen update - FUN_00420590 pattern
 * This handles the login screen state machine from the decompiled function.
 *
 * States from DAT_04630df0:
 * - 0: Initialize, cleanup connection
 * - 1: Load encrypted credentials, init UI
 * - 2: Render and handle input
 * - 3: Create connection widget (FUN_00448610)
 * - 4: Wait for server response, check connection
 * - 100 (0x64): Error display
 * - 101 (0x65): Retry after error
 */
void login_screen_update(void) {
    u32 current_time = timeGetTime();
    int input_result;
    int conn_result;

    switch (g_login.screen_state) {
        case LOGIN_SCREEN_INIT:
            /* State 0: Close existing connection, cleanup */
            login_disconnect();
            memset(g_login.username, 0, sizeof(g_login.username));
            memset(g_login.password, 0, sizeof(g_login.password));
            memset(g_login.encrypted_user, 0, sizeof(g_login.encrypted_user));
            memset(g_login.encrypted_pass, 0, sizeof(g_login.encrypted_pass));
            g_login.input_focus = 0;
            g_login.first_render = 0;
            g_login.screen_state = LOGIN_SCREEN_RENDER;
            LOG_DEBUG("Login screen state 0 -> 1");
            break;

        case LOGIN_SCREEN_RENDER:
            /* State 1: Load encrypted credentials from DAT_0455703c/DAT_04556280 */
            g_login.first_render = 0;

            /* Copy saved credentials if remember password is set */
            if (g_login.remember_pass) {
                /* Decrypt saved credentials - FUN_0048bb90 pattern */
                memcpy(g_login.encrypted_user, g_login.username, sizeof(g_login.encrypted_user));
                memcpy(g_login.encrypted_pass, g_login.password, sizeof(g_login.encrypted_pass));
            }

            g_login.screen_state = LOGIN_SCREEN_INPUT;
            LOG_DEBUG("Login screen state 1 -> 2");
            break;

        case LOGIN_SCREEN_INPUT:
            /* State 2: Handle user input - FUN_00420b70 */
            input_result = login_screen_handle_input();

            if (input_result == 1) {
                /* Login button clicked - transition to connecting */
                g_login.screen_state = LOGIN_SCREEN_CONNECTING;
                LOG_DEBUG("Login screen state 2 -> 3 (connect)");
            }
            else if (input_result == 2) {
                /* Cancel/exit button clicked */
                PostMessageA(GetActiveWindow(), WM_CLOSE, 0, 0);
            }
            else if (input_result < 0) {
                /* Input error - show error message */
                strncpy(g_login.error_message, "Username and password required",
                        sizeof(g_login.error_message) - 1);
                g_login.screen_state = LOGIN_SCREEN_ERROR;
            }
            break;

        case LOGIN_SCREEN_CONNECTING:
            /* State 3: Create connection widget - FUN_00448610 pattern */
            {
                /* Calculate window position - from decompiled */
                int text_len = strlen(g_login.server_name);
                int window_width = ((text_len + 2) * 9 >> 6) + 2;
                int window_x = ((10 - window_width) * 0x40) / 2;
                int window_y = 0xC0;

                /* Create login window - would call FUN_00448610 */
                /* g_login.login_window = ui_window_create(window_x, window_y, window_width, 2, 0, 1); */

                /* Start connection - FUN_0045ef50 */
                g_login.conn_state = CONN_STATE_NONE;  /* Reset state machine */
                g_login.start_time = timeGetTime();

                /* Initiate connection */
                if (login_connect(g_login.server_host, g_login.server_port)) {
                    g_login.screen_state = LOGIN_SCREEN_WAITING;
                    LOG_DEBUG("Login screen state 3 -> 4 (waiting)");
                } else {
                    strncpy(g_login.error_message, "Failed to connect",
                            sizeof(g_login.error_message) - 1);
                    g_login.screen_state = LOGIN_SCREEN_ERROR;
                }
            }
            break;

        case LOGIN_SCREEN_WAITING:
            /* State 4: Wait for server response - FUN_0045ef60 pattern */
            conn_result = login_check_connection();

            if (conn_result == 1) {
                /* Connection successful - decrypt and send credentials */
                /* Copy credentials from encrypted buffers - DAT_0455703c/DAT_04556280 */
                login_encrypt_user_pass(g_login.username, g_login.password,
                                       g_login.encrypted_user, g_login.encrypted_pass);

                /* Send ClientLogin - FUN_0043bb10 */
                if (g_login.protocol_mode == PROTOCOL_MODE_TEXT) {
                    login_auth(g_login.username, g_login.password);
                } else {
                    /* Binary mode - FUN_0048ff00 pattern */
                    login_auth(g_login.username, g_login.password);
                }

                /* Transition to game state - FUN_00479bc0(2) */
                gamestate_set(GAME_STATE_CHAR_SELECT);

                if (g_login.login_window) {
                    /* Destroy login window - FUN_004011c0 */
                    g_login.login_window = 0;
                }
            }
            else if (conn_result == -7) {
                /* Socket error */
                strncpy(g_login.error_message, "Connection failed",
                        sizeof(g_login.error_message) - 1);
                g_login.screen_state = LOGIN_SCREEN_ERROR;
                login_disconnect();
            }
            else if (conn_result == -8) {
                /* DNS error */
                strncpy(g_login.error_message, "DNS lookup failed",
                        sizeof(g_login.error_message) - 1);
                g_login.screen_state = LOGIN_SCREEN_ERROR;
                login_disconnect();
            }
            else if (conn_result < 0) {
                /* Other error */
                strncpy(g_login.error_message, "Connection error",
                        sizeof(g_login.error_message) - 1);
                g_login.screen_state = LOGIN_SCREEN_ERROR;
                login_disconnect();
            }

            /* Check for timeout */
            if (current_time - g_login.start_time > LOGIN_TIMEOUT) {
                strncpy(g_login.error_message, "Connection timeout",
                        sizeof(g_login.error_message) - 1);
                g_login.screen_state = LOGIN_SCREEN_ERROR;
                login_disconnect();
            }
            break;

        case LOGIN_SCREEN_ERROR:
        case LOGIN_SCREEN_RETRY:
            /* State 100/101: Error display and retry */
            /* Wait for user to click retry button - FUN_00420e20 */
            if (input_key_pressed_direct(KEY_RETURN) || input_mouse_clicked(0, 0, 800, 600)) {
                g_login.screen_state = LOGIN_SCREEN_INPUT;
                Sleep(1000);  /* Delay before retry */
            }
            break;
    }
}

/*
 * Initialize text input box - FUN_00420fb0 pattern
 */
void login_init_text_input(TextInputBox* box, int x, int y, int max_len, int is_password, int color) {
    if (!box) return;

    memset(box, 0, sizeof(TextInputBox));

    box->field_10c = x;         /* X position */
    box->field_110 = y;         /* Y position */
    box->max_len = (u8)max_len; /* Max length at +0x105 */
    box->char_width = 8;        /* Character width at +0x108 */
    box->field_11c = color;     /* Color */
    box->field_120 = is_password ? 1 : 0;  /* Password flag */
    box->cursor_index = 0;      /* Cursor position */
    box->render_index = -1;     /* Not yet rendered */
}

/*
 * Update text input box - handles keyboard input
 */
void login_update_text_input(TextInputBox* box) {
    int len;
    char ch;

    if (!box) return;

    len = strlen(box->buffer);

    /* Handle backspace */
    if (input_key_pressed_direct(KEY_BACKSPACE) && len > 0 && box->cursor_index > 0) {
        memmove(&box->buffer[box->cursor_index - 1],
                &box->buffer[box->cursor_index],
                len - box->cursor_index + 1);
        box->cursor_index--;
    }

    /* Handle delete */
    if (input_key_pressed_direct(KEY_DELETE) && box->cursor_index < len) {
        memmove(&box->buffer[box->cursor_index],
                &box->buffer[box->cursor_index + 1],
                len - box->cursor_index);
    }

    /* Handle left arrow */
    if (input_key_pressed_direct(KEY_LEFT) && box->cursor_index > 0) {
        box->cursor_index--;
    }

    /* Handle right arrow */
    if (input_key_pressed_direct(KEY_RIGHT) && box->cursor_index < len) {
        box->cursor_index++;
    }

    /* Handle home */
    if (input_key_pressed_direct(KEY_HOME)) {
        box->cursor_index = 0;
    }

    /* Handle end */
    if (input_key_pressed_direct(KEY_END)) {
        box->cursor_index = len;
    }

    /* Handle character input */
    ch = input_get_char();
    if (ch >= 32 && ch < 127 && len < box->max_len) {
        memmove(&box->buffer[box->cursor_index + 1],
                &box->buffer[box->cursor_index],
                len - box->cursor_index + 1);
        box->buffer[box->cursor_index] = ch;
        box->cursor_index++;
    }
}

/*
 * Render text input box - FUN_0041d890 pattern
 */
void login_render_text_input(TextInputBox* box) {
    char display_buf[256];
    int len;
    int i;
    int cursor_screen_x;

    if (!box) return;

    len = strlen(box->buffer);

    /* Build display string (asterisks for password) */
    if (box->field_120) {
        for (i = 0; i < len && i < box->max_len; i++) {
            display_buf[i] = '*';
        }
        display_buf[i] = '\0';
    } else {
        strncpy(display_buf, box->buffer, sizeof(display_buf) - 1);
        display_buf[sizeof(display_buf) - 1] = '\0';
    }

    /* Calculate cursor screen position */
    cursor_screen_x = box->field_10c + (box->cursor_index * box->char_width);
    box->cursor_pos = cursor_screen_x;
    box->cursor_y = box->field_110;

    /* Add to render queue - FUN_0041d860 pattern */
    if (g_login.first_render) {
        /* Render background box */
        render_fill_rect(g_graphics.back_buffer, box->field_10c - 2, box->field_110 - 2,
                        box->max_len * box->char_width + 4, 20,
                        0x00000000);  /* Black background */

        /* Render text */
        render_text(box->field_10c, box->field_110,
                        display_buf, box->field_11c);

        /* Render cursor */
        render_fill_rect(g_graphics.back_buffer, cursor_screen_x, box->field_110,
                        2, 16, 0xFFFFFFFF);  /* White cursor */
    }
}

/*
 * Handle login screen input - FUN_00420b70 pattern
 * Returns: 0 = normal, 1 = connect clicked, 2 = cancel clicked, -1 = error
 */
int login_screen_handle_input(void) {
    int username_len;
    int password_len;
    int result = 0;

    username_len = strlen(g_login.username);
    password_len = strlen(g_login.password);

    /* Update cursor positions */
    g_login.username_cursor = username_len;
    g_login.password_cursor = password_len;

    /* Check for login button click */
    if (input_mouse_clicked(320, 225, 400, 255)) {
        if (username_len == 0) {
            return -1;  /* Username required */
        }
        if (password_len == 0) {
            return -1;  /* Password required */
        }
        result = 1;  /* Connect */
    }

    /* Check for cancel button click */
    if (input_mouse_clicked(410, 225, 490, 255)) {
        result = 2;  /* Cancel/Exit */
    }

    /* Handle text input focus */
    if (input_mouse_clicked(g_login.username_box.field_10c,
                             g_login.username_box.field_110,
                             g_login.username_box.field_10c + g_login.username_box.max_len * 8,
                             g_login.username_box.field_110 + 16)) {
        g_login.input_focus = 0;  /* Username focus */
    }

    if (input_mouse_clicked(g_login.password_box.field_10c,
                             g_login.password_box.field_110,
                             g_login.password_box.field_10c + g_login.password_box.max_len * 8,
                             g_login.password_box.field_110 + 16)) {
        g_login.input_focus = 1;  /* Password focus */
    }

    /* Handle keyboard input for focused text box */
    if (g_login.input_focus == 0) {
        login_update_text_input(&g_login.username_box);
        strcpy(g_login.username, g_login.username_box.buffer);
    } else {
        login_update_text_input(&g_login.password_box);
        strcpy(g_login.password, g_login.password_box.buffer);
    }

    /* Tab to switch focus */
    if (input_key_pressed_direct(KEY_TAB)) {
        g_login.input_focus = 1 - g_login.input_focus;
    }

    /* Enter key to submit */
    if (input_key_pressed_direct(KEY_RETURN)) {
        if (username_len > 0 && password_len > 0) {
            result = 1;
        }
    }

    return result;
}

/*
 * Check connection status - FUN_0045ef60 pattern
 * Returns: 1 = connected, 0 = waiting, negative = error
 *
 * From decompiled analysis:
 * - Checks DAT_0461bb60 for 'L' (login success)
 * - Sets DAT_0461b658 = 0xf000001 for binary mode
 * - Returns -7 for socket error, -8 for DNS error
 * - Returns -6 for connection closed
 * - Returns -1 for timeout (600000ms)
 */
int login_check_connection(void) {
    u32 current_time;
    int socket_status;
    fd_set read_fds, write_fds, except_fds;
    struct timeval timeout;
    int select_result;

    /* Check for login success marker - DAT_0461bb60 == 'L' */
    if (g_login.first_byte == 'L') {
        g_login.protocol_mode = PROTOCOL_MODE_BINARY;  /* 0x0F000000 */
        g_login.conn_state = CONN_STATE_SEND_LOGIN;
        return 1;
    }

    /* Check for invalid first byte */
    if (g_login.first_byte != 0 && g_login.first_byte != 'A' && g_login.first_byte != 'E') {
        return LOGIN_ERR_DNS_FAILED;  /* -8 */
    }

    /* Check socket status using select - FUN_0045f4d0 pattern */
    FD_ZERO(&read_fds);
    FD_ZERO(&write_fds);
    FD_ZERO(&except_fds);
    FD_SET(g_net.socket, &read_fds);
    FD_SET(g_net.socket, &write_fds);
    FD_SET(g_net.socket, &except_fds);

    timeout.tv_sec = 0;
    timeout.tv_usec = 0;

    select_result = select((int)g_net.socket + 1, &read_fds, &write_fds, &except_fds, &timeout);

    if (select_result > 0) {
        /* Check for read data */
        if (FD_ISSET(g_net.socket, &read_fds)) {
            /* Receive first byte - DAT_0461bb60 */
            int recv_result = recv(g_net.socket, (char*)&g_login.first_byte, 1, 0);
            if (recv_result > 0) {
                if (g_login.first_byte == 'E') {
                    /* Server error response */
                    strncpy(g_login.error_message, "Server error", sizeof(g_login.error_message) - 1);
                    return LOGIN_ERR_SOCKET_ERROR;  /* -7 */
                }
                if (g_login.first_byte == 'A') {
                    /* Server accepted - switch to binary mode */
                    g_login.protocol_mode = PROTOCOL_MODE_BINARY;  /* 0x0F000001 */
                    if (FD_ISSET(g_net.socket, &write_fds)) {
                        g_login.conn_state = CONN_STATE_SEND_LOGIN;  /* 0x47 */
                        g_net.initialized = 1;  /* DAT_0461b3fc */
                    }
                }
            }
        }

        /* Check for exception */
        if (FD_ISSET(g_net.socket, &except_fds)) {
            strncpy(g_login.error_message, "Connection error", sizeof(g_login.error_message) - 1);
            return LOGIN_ERR_CONNECTION_FAILED;  /* -6 */
        }
    }

    /* Check for timeout - 600000ms from FUN_0045f4d0 */
    current_time = timeGetTime();
    if (current_time - g_login.start_time > LOGIN_TIMEOUT) {
        strncpy(g_login.error_message, "Connection timeout", sizeof(g_login.error_message) - 1);
        return LOGIN_ERR_TIMEOUT;  /* -1 */
    }

    return 0;  /* Still waiting */
}

/*
 * Render login screen - FUN_00420590 state 1 pattern
 */
void login_screen_render(void) {
    /* Render background */
    render_fill_rect(g_graphics.back_buffer, 0, 0, 800, 600, 0x00404040);

    /* Render title */
    render_text(350, 100, "Stone Age", 0xFFFFFFFF);

    /* Render username label */
    render_text(220, 170, "Username:", 0xFFFFFFFF);

    /* Render password label */
    render_text(220, 200, "Password:", 0xFFFFFFFF);

    /* Render text input boxes */
    login_render_text_input(&g_login.username_box);
    login_render_text_input(&g_login.password_box);

    /* Render login button */
    render_fill_rect(g_graphics.back_buffer, 320, 240, 80, 30, 0x00606060);
    render_text(340, 247, "Login", 0xFFFFFFFF);

    /* Render cancel button */
    render_fill_rect(g_graphics.back_buffer, 420, 240, 80, 30, 0x00606060);
    render_text(438, 247, "Exit", 0xFFFFFFFF);

    /* Render error message if any */
    if (g_login.screen_state == LOGIN_SCREEN_ERROR && g_login.error_message[0]) {
        render_text(250, 290, g_login.error_message, 0x0000FF00);  /* Green error text */
    }

    /* Render server status */
    if (g_login.server_player_count > 0) {
        char status[64];
        _snprintf(status, sizeof(status), "Players: %d", g_login.server_player_count);
        render_text(350, 350, status, 0xFFFFFFFF);
    }

    g_login.first_render = 1;
}
